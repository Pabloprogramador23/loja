# ============================================================
# Variáveis de ambiente — loja SaaS
# Copie este arquivo para .env e preencha os valores reais.
# Nunca commite o .env com valores reais.
# ============================================================

# Django core
# Gere uma nova chave com:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=substitua-por-uma-chave-secreta-gerada

# False em produção, True apenas em desenvolvimento local
DEBUG=False

# Hosts aceitos pelo Django (separados por vírgula)
# Produção: ALLOWED_HOSTS=meusaas.com,*.meusaas.com
# Dev local: ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================
# Banco de dados
# ============================================================
# Produção: postgresql://usuario:senha@host:5432/nome_db
# Dev local (SQLite, deixe em branco para usar o padrão):
DATABASE_URL=sqlite:///db.sqlite3

# ============================================================
# Redis / Celery
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# MercadoPago
# ============================================================
# Token de acesso padrão (pode ser sobrescrito por loja no admin)
# Use um token de teste para dev: TEST-xxx...
MERCADOPAGO_ACCESS_TOKEN=TEST-00000000-0000-0000-0000-000000000000

# Segredo para validar assinatura HMAC dos webhooks
# Obtenha em: painel MP → Suas integrações → Webhooks → Segredo de assinatura
MERCADOPAGO_WEBHOOK_SECRET=

# ============================================================
# Testes / desenvolvimento
# ============================================================
# Quando true, habilita endpoints de teste (ex: approvar pedido via webhook mock)
# NUNCA defina como true em produção
REVERSA_TESTING=false
